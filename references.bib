    url = {https://onlinelibrary.wiley.com/doi/full/10.1002/9781118445112.stat08068 https://onlinelibrary.wiley.com/doi/abs/10.1002/9781118445112.stat08068 https://onlinelibrary.wiley.com/doi/10.1002/9781118445112.stat08068},
